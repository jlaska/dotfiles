  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=capsule --theme=dark"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "obsidian-productivity@obsidian-claude-plugins": true,
    "markdown-linter-fixer@markdown-linter-fixer-marketplace": true,
    "che-ical-mcp@psychquant-claude-plugins": true,
    "astral@astral-sh": true
  },
  "extraKnownMarketplaces": {
    "markdown-linter-fixer-marketplace": {
      "source": {
        "source": "git",
        "url": "https://github.com/s2005/markdown-linter-fixer-skill.git"
      }
    },
    "psychquant-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "PsychQuant/psychquant-claude-plugins"
      }
    },
    "astral-sh": {
      "source": {
        "source": "github",
        "repo": "astral-sh/claude-code-plugins"
      }
    }
  },
  "effortLevel": "medium",
  "mcpServers": {
    "wdcli": {
      "type": "stdio",
      "command": "wdcli",
      "args": [
        "mcp",
        "serve"
      ]
    }
  },
