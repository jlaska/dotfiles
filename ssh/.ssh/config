# Machine-local SSH host overrides (Tailscale hosts, personal devices, etc.)
# File not tracked — create ~/.ssh/config.local with per-machine entries.
Include ~/.ssh/config.local

IdentityFile ~/.ssh/id_yubikey.pub
IdentitiesOnly yes

Host *.redhat.com
    User jlaska
    GSSAPIAuthentication yes

Host 10.0.*.1
    User root

Host *.fedoraproject.org fedorapeople.org
    User jlaska
    VerifyHostKeyDNS yes

Host *github.com
    User jlaska
    ForwardAgent yes

Host 192.168.* 172.16.* 10.*
    # User root
    CheckHostIP no
    UserKnownHostsFile /dev/null
    StrictHostKeyChecking no

Host *.amazonaws.com 54.211.*
    # NOTE: not all ec2 instances allow login as 'root'
    # User root
    CheckHostIP     no
    UserKnownHostsFile      /dev/null
    StrictHostKeyChecking   no
